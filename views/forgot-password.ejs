<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<nav class="auth-nav"><a href="/" class="auth-nav__brand"><img src="/icons/Atlasphere Logo.svg" alt="Atlasphere" class="navbar-logo"></a><a href="/auth/login" class="auth-nav__btn">Log in</a></nav>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/login-mountain.jpg" alt="Mountain"></div>
    <div class="framed-box__content" style="display:flex;align-items:center;justify-content:center;">
      <div class="auth-card">
        <h1>Forgot Password</h1>
        <p style="font-size:14px;color:rgba(255,255,255,0.6);margin-bottom:20px;text-align:center;">Enter your email and we'll send you a link to reset your password.</p>
        <% if (typeof error !== 'undefined' && error) { %><div class="msg-error"><%= error %></div><% } %>
        <% if (typeof success !== 'undefined' && success) { %><div class="msg-success"><%= success %></div><% } %>
        <form action="/auth/forgot-password" method="post">
          <div class="auth-fg"><label for="email">Email</label><input type="email" id="email" name="email" placeholder="Enter your email" required></div>
          <button type="submit" class="auth-submit">Send Reset Link</button>
        </form>
        <p style="margin-top:16px;"><a href="/auth/login">Back to Sign In</a></p>
      </div>
    </div>
  </div>
</div>
<script>var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);</script>
</body>
</html>
