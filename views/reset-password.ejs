<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<nav class="auth-nav"><a href="/" class="auth-nav__brand"><img src="/icons/Atlasphere Logo.svg" alt="Atlasphere" class="navbar-logo"></a><a href="/auth/login" class="auth-nav__btn">Log in</a></nav>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/login-mountain.jpg" alt="Mountain"></div>
    <div class="framed-box__content" style="display:flex;align-items:center;justify-content:center;">
      <div class="auth-card">
        <h1>Reset Password</h1>
        <% if (typeof error !== 'undefined' && error) { %><div class="msg-error"><%= error %></div><% } %>
        <% if (typeof success !== 'undefined' && success) { %><div class="msg-success"><%= success %></div><% } %>
        <form action="/auth/reset-password" method="post">
          <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>">
          <div class="auth-fg"><label for="password">New Password</label><input type="password" id="password" name="password" placeholder="Min 6 characters" minlength="6" maxlength="12" required></div>
          <div class="auth-fg"><label for="confirmPassword">Confirm Password</label><input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm password" minlength="6" maxlength="12" required></div>
          <button type="submit" class="auth-submit">Reset Password</button>
        </form>
      </div>
    </div>
  </div>
</div>
<script>var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);</script>
</body>
</html>
