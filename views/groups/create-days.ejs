<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trip Length - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/setup-desert.jpg" alt="Desert landscape"></div>
    <div class="framed-box__content" style="display:flex;align-items:center;justify-content:center;">
      <div class="group-creation-content">
        <h1>How long do you plan to spend?</h1>
        <p>Drag the toggle to select the number of days</p>

        <form action="/groups/create/confirm" method="get">
          <input type="hidden" name="country" value="<%= typeof country !== 'undefined' ? country : '' %>">
          <input type="hidden" name="cities" value="<%= typeof cities !== 'undefined' ? cities : '' %>">
          <div class="slider-container">
            <input type="range" min="1" max="30" value="10" class="slider-track" id="slideRange" name="days">
            <p class="slider-value"><span id="daysValue">10</span> Days</p>
          </div>
          <div class="setup-actions" style="margin-top: 40px;">
            <button type="submit" class="btn btn-primary">Next</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  var slider = document.getElementById('slideRange');
  var output = document.getElementById('daysValue');
  output.textContent = slider.value;
  slider.addEventListener('input', function() { output.textContent = this.value; });
</script>
</body>
</html>
