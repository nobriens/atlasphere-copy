<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Group Created - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/setup-desert.jpg" alt="Desert"></div>
    <div class="framed-box__content">
      <div class="gc-content">
        <div class="gc-left">
          <h1>Your &ldquo;<%= typeof group !== 'undefined' && group ? group.name : 'My Trip' %>&rdquo; group<br>has been created!</h1>
          <% if (typeof inviteSuccess !== 'undefined' && inviteSuccess) { %><div class="msg-success gc-invite-msg"><%= inviteSuccess %></div><% } %>
          <% if (typeof inviteError !== 'undefined' && inviteError) { %><div class="msg-error gc-invite-msg"><%= inviteError %></div><% } %>
          <p class="gc-invite-label">Invite a friend by email or username</p>
          <form action="/groups/invite" method="post" class="gc-search" id="inviteForm">
            <input type="hidden" name="groupId" value="<%= typeof group !== 'undefined' && group ? group.id : '' %>">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;opacity:0.6;">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" name="friendInput" id="friendInput" placeholder="Email or username..." required>
            <button type="submit" style="background:none;border:none;color:rgba(255,255,255,0.5);cursor:pointer;display:inline-flex;align-items:center;padding:2px;transition:color 0.15s;" onmouseover="this.style.color='#E8933A'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </button>
          </form>
          <p class="gc-or">or</p>
          <button type="button" class="gc-share-btn" onclick="copyLink()">Share Link</button>
          <input type="hidden" id="inviteLinkHidden" value="<%= typeof inviteLink !== 'undefined' ? inviteLink : '' %>">
          <br>
          <a href="/groups/create/activities?groupId=<%= typeof group !== 'undefined' && group ? group.id : '' %>" class="gc-go-btn">Continue to Activities</a>
        </div>
        <div class="gc-right">
          <form action="/groups/upload-photo" method="post" enctype="multipart/form-data" id="groupPhotoForm">
            <input type="hidden" name="groupId" value="<%= typeof group !== 'undefined' && group ? group.id : '' %>">
            <div class="gc-upload-circle" id="uploadCircle" onclick="document.getElementById('groupPicInput').click();" style="cursor:pointer;">
              <svg class="gc-img-icon" id="photoPlaceholder" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="4" stroke="#9aa" stroke-width="1.5"/><path d="M2 16l5-5 4 4 3-3 8 8H6a4 4 0 01-4-4v0z" fill="#bcc"/><circle cx="8.5" cy="8.5" r="2" fill="#bcc"/></svg>
              <img class="gc-preview" id="previewImg" alt="Preview">
              <input type="file" name="groupPhoto" accept="image/*" id="groupPicInput" style="display:none;">
            </div>
            <button type="button" class="gc-upload-btn" id="uploadBtn" onclick="document.getElementById('groupPicInput').click();">Upload Group Picture</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="copied-toast" id="copiedToast">Link copied!</div>
<script>
  var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);
  function copyLink(){var l=document.getElementById('inviteLinkHidden').value;if(!l)return;navigator.clipboard.writeText(l).then(function(){var t=document.getElementById('copiedToast');t.style.display='block';setTimeout(function(){t.style.display='none';},2000);});}

  document.getElementById('inviteForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var input = document.getElementById('friendInput');
    var val = input.value.trim();
    if (!val) return;
    var old1 = this.querySelector('input[name="friendEmail"]');
    var old2 = this.querySelector('input[name="friendUsername"]');
    if (old1) old1.remove();
    if (old2) old2.remove();
    var hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.name = val.includes('@') ? 'friendEmail' : 'friendUsername';
    hidden.value = val;
    this.appendChild(hidden);
    this.submit();
  });

  document.getElementById('groupPicInput').addEventListener('change',function(e){
    var f=e.target.files[0];
    if(!f)return;
    var r=new FileReader();
    r.onload=function(ev){
      var i=document.getElementById('previewImg');
      i.src=ev.target.result;
      i.style.display='block';
      document.getElementById('photoPlaceholder').style.display='none';
    };
    r.readAsDataURL(f);
    var btn=document.getElementById('uploadBtn');
    btn.textContent='Save Group Picture';
    btn.onclick=function(){ document.getElementById('groupPhotoForm').submit(); };
  });
</script>
</body>
</html>
