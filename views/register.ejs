<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<nav class="auth-nav"><a href="/" class="auth-nav__brand"><img src="/icons/Atlasphere Logo.svg" alt="Atlasphere" class="navbar-logo"></a><a href="/auth/login" class="auth-nav__btn">Log in</a></nav>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/registration-lake.jpg" alt="Lake"></div>
    <div class="framed-box__content" style="display:flex;align-items:center;justify-content:center;">
      <div class="auth-card">
        <h1>Registration</h1>
        <% if (typeof error !== 'undefined' && error) { %><div class="msg-error"><%= error %></div><% } %>
        <form action="/auth/register" method="post">
          <div class="auth-fg"><label for="username">Name</label><input type="text" id="username" name="username" placeholder="Enter your name" required></div>
          <div class="auth-fg"><label for="useremail">Email</label><input type="email" id="useremail" name="useremail" placeholder="Enter your email" required></div>
          <div class="auth-fg"><label for="userphone">Phone</label><div class="auth-phone-row"><select name="phoneCode" class="phone-prefix" id="phoneCode">
            <option value="+353">🇮🇪 +353</option>
            <option value="+44">🇬🇧 +44</option>
            <option value="+1">🇺🇸 +1</option>
            <option value="+49">🇩🇪 +49</option>
            <option value="+33">🇫🇷 +33</option>
            <option value="+34">🇪🇸 +34</option>
            <option value="+39">🇮🇹 +39</option>
            <option value="+31">🇳🇱 +31</option>
            <option value="+32">🇧🇪 +32</option>
            <option value="+41">🇨🇭 +41</option>
            <option value="+43">🇦🇹 +43</option>
            <option value="+45">🇩🇰 +45</option>
            <option value="+46">🇸🇪 +46</option>
            <option value="+47">🇳🇴 +47</option>
            <option value="+48">🇵🇱 +48</option>
            <option value="+351">🇵🇹 +351</option>
            <option value="+358">🇫🇮 +358</option>
            <option value="+36">🇭🇺 +36</option>
            <option value="+30">🇬🇷 +30</option>
            <option value="+90">🇹🇷 +90</option>
            <option value="+91">🇮🇳 +91</option>
            <option value="+86">🇨🇳 +86</option>
            <option value="+81">🇯🇵 +81</option>
            <option value="+82">🇰🇷 +82</option>
            <option value="+61">🇦🇺 +61</option>
            <option value="+64">🇳🇿 +64</option>
            <option value="+55">🇧🇷 +55</option>
            <option value="+52">🇲🇽 +52</option>
            <option value="+27">🇿🇦 +27</option>
            <option value="+234">🇳🇬 +234</option>
            <option value="+254">🇰🇪 +254</option>
            <option value="+20">🇪🇬 +20</option>
            <option value="+971">🇦🇪 +971</option>
            <option value="+966">🇸🇦 +966</option>
            <option value="+7">🇷🇺 +7</option>
            <option value="+380">🇺🇦 +380</option>
            <option value="+40">🇷🇴 +40</option>
            <option value="+385">🇭🇷 +385</option>
            <option value="+381">🇷🇸 +381</option>
            <option value="+355">🇦🇱 +355</option>
            <option value="+387">🇧🇦 +387</option>
          </select><input type="tel" id="userphone" name="userphone" placeholder="Phone number" required></div></div>
          <div class="auth-fg"><label for="gender">Gender</label><select id="gender" name="gender"><option value="">Select gender</option><option value="1">Male</option><option value="2">Female</option><option value="3">Diverse</option></select></div>
          <div class="auth-fg"><label for="psw">Password</label><input type="password" id="psw" name="psw" minlength="6" maxlength="12" placeholder="Min 6, max 12 characters" required></div>
          <button type="submit" class="auth-submit">Register</button>
        </form>
        <p>Already have an account? <a href="/auth/login">Sign in</a></p>
      </div>
    </div>
  </div>
</div>
<script>var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);</script>
</body>
</html>
