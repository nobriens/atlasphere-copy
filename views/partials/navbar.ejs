<!-- Navigation Bar -->
<nav class="navbar" id="atlasphere-navbar" <% if (typeof user !== 'undefined' && user) { %>data-user-id="<%= user.id %>"<% } else { %>data-user-id=""<% } %>>
  <div class="navbar-left">
    <a href="/" class="navbar-brand">
  <img src="/icons/Atlasphere Logo.svg" alt="Atlasphere" class="navbar-logo">
</a>
  </div>

  <div class="navbar-center">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/" class="nav-link">Home</a>
      <a href="/groups" class="nav-link nav-link--groups">Groups<span id="navbar-groups-badge" class="navbar-groups-badge"></span></a>
      <a href="/profile" class="nav-link">Profile</a>
      <a href="/settings" class="nav-link">Settings</a>
    <% } %>
  </div>

  <div class="navbar-right">
    <% if (typeof user !== 'undefined' && user) { %>
    <!-- Notification Bell -->
    <div class="notif-wrapper" id="notifWrapper">
      <button class="notif-bell" id="notifBell" aria-label="Notifications">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
      </button>
      <div class="notif-dropdown" id="notifDropdown" style="display:none;">
        <div class="notif-dropdown__header">
          <span class="notif-dropdown__title">Notifications</span>
          <button class="notif-dropdown__clear" id="notifClear">Mark all read</button>
        </div>
        <div class="notif-dropdown__list" id="notifList">
          <div class="notif-dropdown__empty">No notifications</div>
        </div>
      </div>
    </div>
    <% } %>

    <label class="theme-switch" aria-label="Toggle dark/light mode">
      <input type="checkbox" id="themeToggle">
      <div class="theme-switch__track"></div>
      <div class="theme-switch__knob"></div>
    </label>

    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/auth/logout" class="btn btn-primary btn-sm">Sign out</a>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary btn-sm">Log in</a>
    <% } %>
  </div>
</nav>

<link rel="stylesheet" href="/css/chat-notification.css">
<script src="/js/chat-notification.js" defer></script>

<script>
  (function() {
    // Theme toggle
    const toggle = document.getElementById('themeToggle');
    const html = document.documentElement;
    const saved = localStorage.getItem('atlasphere-theme') || 'light';
    html.setAttribute('data-theme', saved);
    if (saved === 'light') toggle.checked = true;
    toggle.addEventListener('change', () => {
      const next = toggle.checked ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('atlasphere-theme', next);
    });

    // Notifications
    const bell = document.getElementById('notifBell');
    const dropdown = document.getElementById('notifDropdown');
    const badge = document.getElementById('notifBadge');
    const list = document.getElementById('notifList');
    const clearBtn = document.getElementById('notifClear');
    if (!bell) return;

    function timeAgo(dateStr) {
      var diff = (Date.now() - new Date(dateStr).getTime()) / 1000;
      if (diff < 60) return 'just now';
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      return Math.floor(diff / 86400) + 'd ago';
    }

    function loadNotifications() {
      fetch('/api/notifications').then(r => r.json()).then(data => {
        var unread = data.filter(n => !n.isRead).length;
        badge.textContent = unread;
        badge.style.display = unread > 0 ? '' : 'none';

        if (data.length === 0) {
          list.innerHTML = '<div class="notif-dropdown__empty">No notifications</div>';
          return;
        }
        list.innerHTML = '';
        data.slice(0, 20).forEach(function(n) {
          var item = document.createElement('div');
          item.className = 'notif-item' + (n.isRead ? '' : ' notif-item--unread');
          var icon = n.type === 'vote-summary' ? '📊' : n.type === 'invite' ? '✉️' : '👍';
          item.innerHTML = '<span class="notif-item__icon">' + icon + '</span>' +
            '<div class="notif-item__body">' +
              '<div class="notif-item__msg">' + n.message + '</div>' +
              '<div class="notif-item__meta">' + (n.groupName || '') + ' · ' + timeAgo(n.createdAt) + '</div>' +
            '</div>';
          item.addEventListener('click', function() {
            var gid = n.groupId ? String(n.groupId) : null;
            if (gid) window.location.href = '/groups/' + gid;
          });
          list.appendChild(item);
        });
      }).catch(() => {});
    }

    function loadCount() {
      fetch('/api/notifications/count').then(r => r.json()).then(data => {
        badge.textContent = data.count || 0;
        badge.style.display = data.count > 0 ? '' : 'none';
      }).catch(() => {});
    }

    bell.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = dropdown.style.display !== 'none';
      dropdown.style.display = open ? 'none' : 'block';
      if (!open) {
        loadNotifications();
        // Mark all as read when opening
        fetch('/api/notifications/read', { method: 'POST' }).then(function() {
          badge.style.display = 'none';
          badge.textContent = '0';
        });
      }
    });

    clearBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      fetch('/api/notifications/read', { method: 'POST' }).then(() => {
        badge.style.display = 'none';
        badge.textContent = '0';
        loadNotifications();
      });
    });

    document.addEventListener('click', function(e) {
      if (!document.getElementById('notifWrapper').contains(e.target)) {
        dropdown.style.display = 'none';
      }
    });

    // Poll for new notifications every 30s
    loadCount();
    setInterval(loadCount, 30000);

    // Listen for socket notifications
    if (typeof io !== 'undefined') {
      try {
        var ns = io();
        ns.on('new-notification', function() { loadCount(); });
      } catch(e) {}
    }
  })();

  // Active nav link highlighting
  (function() {
    var path = window.location.pathname;
    var links = document.querySelectorAll('.nav-link');
    links.forEach(function(link) {
      var href = link.getAttribute('href');
      if (href === '/' && path === '/') {
        link.classList.add('nav-link--active');
      } else if (href !== '/' && path.startsWith(href)) {
        link.classList.add('nav-link--active');
      }
    });
  })();
</script>
